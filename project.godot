; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="RTS"
run/main_scene="res://world/maps/map_0.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
run/max_fps=240

[autoload]

Util="*res://autoload/util.gd"
SignalBus="*res://autoload/signal_bus.gd"
Global="*res://autoload/global.gd"

[debug]

gdscript/warnings/unused_signal=0

[display]

window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[dotnet]

project/assembly_name="RTS"

[file_customization]

folder_colors={
"res://autoload/": "gray",
"res://camera/": "blue",
"res://camera/modules/": "red",
"res://commands/": "red",
"res://commands/unit_commands/": "blue",
"res://items/": "orange",
"res://ui/": "pink",
"res://ui/rts/": "orange",
"res://units/": "blue",
"res://units/components/": "red",
"res://units/groups/": "yellow",
"res://units/groups/formations/": "green",
"res://units/jobs/": "teal",
"res://units/materials/": "green",
"res://units/portraits/": "purple",
"res://user/": "purple",
"res://user/controllers/": "blue",
"res://user/modules/": "red",
"res://user/modules/rts_modules/": "yellow",
"res://user/modules/unit_control_modules/": "green",
"res://world/": "green",
"res://world/buildings/": "orange",
"res://world/buildings/military/": "red",
"res://world/buildings/production/": "yellow",
"res://world/buildings/resource/": "gray",
"res://world/buildings/resource/buildings/": "orange",
"res://world/buildings/resource/spawns/": "purple",
"res://world/landmarks/": "teal",
"res://world/maps/": "purple"
}

